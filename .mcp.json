{
  "name": "fishkeeper-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 Sovereign AI tools for everyone.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "analyze_water_params",
      "description": "Analyze aquarium water parameters and return health assessment.",
      "parameters": {
        "type": "object",
        "properties": {
          "ph": {
            "type": "number"
          },
          "ammonia_ppm": {
            "type": "number"
          },
          "nitrite_ppm": {
            "type": "number"
          },
          "nitrate_ppm": {
            "type": "number"
          },
          "temperature_c": {
            "type": "number"
          },
          "gh_dgh": {
            "type": "number"
          },
          "kh_dgh": {
            "type": "number"
          },
          "tank_type": {
            "type": "string"
          }
        },
        "required": [
          "ph",
          "ammonia_ppm",
          "nitrite_ppm",
          "nitrate_ppm",
          "temperature_c"
        ]
      }
    },
    {
      "name": "identify_fish",
      "description": "Identify fish species and return detailed care requirements.",
      "parameters": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "species_name": {
            "type": "string"
          }
        },
        "required": []
      }
    },
    {
      "name": "check_compatibility",
      "description": "Check if multiple fish species are compatible in the same tank.",
      "parameters": {
        "type": "object",
        "properties": {
          "species_list": {
            "type": "array"
          }
        },
        "required": [
          "species_list"
        ]
      }
    },
    {
      "name": "diagnose_disease",
      "description": "Diagnose fish disease from symptoms and suggest treatments.",
      "parameters": {
        "type": "object",
        "properties": {
          "symptoms": {
            "type": "array"
          },
          "species": {
            "type": "string"
          },
          "water_params": {
            "type": "object"
          }
        },
        "required": [
          "symptoms"
        ]
      }
    },
    {
      "name": "calculate_stocking",
      "description": "Calculate maximum fish stocking for a tank.",
      "parameters": {
        "type": "object",
        "properties": {
          "tank_litres": {
            "type": "number"
          },
          "tank_length_cm": {
            "type": "number"
          },
          "species_list": {
            "type": "array"
          },
          "filtration_quality": {
            "type": "string"
          },
          "planted": {
            "type": "boolean"
          }
        },
        "required": [
          "tank_litres"
        ]
      }
    },
    {
      "name": "get_feeding_schedule",
      "description": "Generate a feeding schedule based on species mix.",
      "parameters": {
        "type": "object",
        "properties": {
          "species_list": {
            "type": "array"
          },
          "tank_type": {
            "type": "string"
          }
        },
        "required": [
          "species_list"
        ]
      }
    }
  ]
}